# =============================================================================
# Autodsm — environment template
# =============================================================================
# Copy this file to `.env.local` (recommended) or `.env` in the project root.
# Next.js loads `.env.local` with highest priority for local dev.
# Never commit real keys — only this example file may be in git.
#
# Where to set production/preview: Vercel → Project → Settings → Environment
# =============================================================================

# ─── Supabase (app + auth) ─────────────────────────────────────────────────
# [REQUIRED for login, dashboard, and repo scans] Supabase Dashboard →
#   Project Settings → API → Project URL, anon key, and service_role (server only).

# → FILL IN: your project URL (https://<project-ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# → FILL IN: use ONE of the public client keys (same key, two possible names in the dashboard)
#   New projects: "publishable" / sb_publishable_…
#   Legacy: "anon" / eyJ…
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# If you do not use publishable, set this instead (leave publishable empty):
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [OPTIONAL] Vercel Supabase integration often injects these without NEXT_PUBLIC_;
# next.config bridges them for the browser. You can leave empty if the four vars above are set.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Also accepted as a public key fallback (unprefixed):
# SUPABASE_PUBLISHABLE_KEY=

# [REQUIRED for server actions that use the admin client, e.g. Storage uploads for brand assets]
# → FILL IN: service_role key (keep server-only; never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Supabase Auth — email magic link (optional) ─────────────────────────────
# Enable Email in Dashboard → Authentication → Providers. Magic link is started from the
# login page in the browser (PKCE cookies); set NEXT_PUBLIC_APP_URL in prod so emailRedirectTo
# matches your allow-list. For server-side /auth/callback (cookie session), customize the
# Magic Link template so the link opens your app with token_hash and type in the QUERY STRING
# (not only the default fragment redirect).
# Example anchor href (Go template): {{ if .RedirectTo }}<a href="{{ .RedirectTo }}?token_hash={{ .TokenHash }}&type=email">Sign in</a>{{ end }}
# Use the same Site URL / Redirect URLs as OAuth (…/auth/callback). Local: Inbucket on port 54324.

# ─── Supabase Storage (brand-asset raster uploads from scans) ────────────────
# [RECOMMENDED] If unset, scans still run but skip uploading images to Storage.
# Create a bucket in Supabase → Storage; RLS so users can write under `brand-assets/{userId}/…`.
# → FILL IN: must match the bucket *id* in the dashboard (often `brand-assets`).
BRAND_ASSETS_BUCKET=brand-assets

# ─── Supabase CLI / migrations (local only) ────────────────────────────────
# [OPTIONAL] For `scripts/supabase-db-push.sh` or `npx supabase db push` using direct Postgres.
# Dashboard → Project Settings → Database → password (not the same as API keys).
# SUPABASE_DB_PASSWORD=
# If your project ref is not the default the script expects:
# SUPABASE_PROJECT_REF=
# Or pass a full connection string (port 5432) instead of building from password + ref:
# DIRECT_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.<project-ref>.supabase.co:5432/postgres
# DATABASE_URL=   # same idea; script accepts either DIRECT_URL or DATABASE_URL

# ─── GitHub App (repo access for scanning) ─────────────────────────────────
# [REQUIRED for full GitHub integration] https://github.com/settings/apps/new
#   Contents: read, Metadata: read | Events: push
#   Callback: ${NEXT_PUBLIC_APP_URL}/auth/callback
#   Setup URL: ${NEXT_PUBLIC_APP_URL}/onboarding

# → FILL IN: numeric App ID from the app settings page
GITHUB_APP_ID=
# → FILL IN: multiline PEM (use \n for newlines in a single line, or a file path if your host supports it)
GITHUB_APP_PRIVATE_KEY=
# Public slug in URLs (default below matches a typical name; change if your app slug differs)
GITHUB_APP_SLUG=autodsm
# → FILL IN: the secret you configure for webhook delivery verification
GITHUB_APP_WEBHOOK_SECRET=

# [OPTIONAL] Higher GitHub API rate limit for public repos when no installation exists (else ~60/hr)
# → FILL IN: classic PAT with `public_repo` or fine-grained read on needed repos
GITHUB_API_TOKEN=

# ─── AI (Gemini) ───────────────────────────────────────────────────────────
# [OPTIONAL] App runs without; AI assists (component copy, render repair) are disabled.
# → FILL IN: https://aistudio.google.com/apikey or Google AI Studio
GEMINI_API_KEY=

# ─── App URL ───────────────────────────────────────────────────────────────
# [REQUIRED] OAuth redirect base — no trailing slash.
# Local: http://localhost:3000  |  Production: your Vercel URL or custom domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [OPTIONAL] If 1, show onboarding preview on /login outside development
# NEXT_PUBLIC_ONBOARDING_DEV_PREVIEW=1

# [OPTIONAL, local dev only] Mock authenticated dashboard without Supabase login
# (add to .env.local; restart `next dev`)
# DEV_AUTH_BYPASS=true
# DEV_PREVIEW_REPO=vercel/next.js

# Preview / E2E: dashboard test bypass (never enable in Vercel Production; never commit
# with bypass flags as real values). Variable names and setup: `docs/E2E_PREVIEW.md`
